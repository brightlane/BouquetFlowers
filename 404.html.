<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #fff5f8;
      color: #333;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
    }

    .container {
      max-width: 500px;
      padding: 20px;
    }

    h1 {
      font-size: 72px;
      margin: 0;
      color: #e91e63;
    }

    p {
      font-size: 18px;
      margin: 10px 0 20px;
    }

    a {
      display: inline-block;
      padding: 10px 18px;
      background: #e91e63;
      color: white;
      text-decoration: none;
      border-radius: 6px;
    }

    a:hover {
      background: #c2185b;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>404</h1>
    <p>Oops! The page you’re looking for doesn’t exist.</p>
    <a href="/BouquetFlowers/">Go Back Home</a>
  </div>
</body>
</html>
